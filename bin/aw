#!/usr/bin/env bash
# aw — agentic-workspace CLI
#
# Flow (post-pivot 2026-06-07) :
#   1. Session main interactive (chez l'humain) : alignement + `aw new <name>`
#      + remplit `inputs/prompt.md` complet.
#   2. Humain lance une session dédiée : `cd workspaces/<name> && claude`.
#      L'agent appelle `aw start` au boot, bosse, `aw end` à sa dernière action.
#   3. Main reprend, audit la livraison, appelle `aw report <name> "<note>"`
#      qui lit les timestamps et écrit le bilan + duration_seconds.
#
# Config : ~/.agentic-workspace/config.json (créé par install.sh).

set -euo pipefail

CONFIG_DIR="$HOME/.agentic-workspace"
CONFIG_FILE="$CONFIG_DIR/config.json"

load_config() {
  if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: no config at $CONFIG_FILE." >&2
    echo "Run install.sh from the agentic-workspace repo to create it." >&2
    exit 1
  fi
  REPO_PATH="$(jq -r '.repo_path' "$CONFIG_FILE")"
  REPORTS_PATH="$(jq -r '.reports_path' "$CONFIG_FILE")"
  if [ -z "$REPO_PATH" ] || [ ! -d "$REPO_PATH" ]; then
    echo "Error: repo_path '$REPO_PATH' from $CONFIG_FILE is invalid." >&2
    echo "Re-run install.sh from the current location of the repo." >&2
    exit 1
  fi
}

cmd_help() {
  cat <<EOF
aw — agentic-workspace CLI

  aw new <name>                Create \$PWD/workspaces/<name>/ (inputs/prompt.md à remplir)
  aw start                     [workspace agent] Mark timer start (\$PWD/.started_at)
  aw end                       [workspace agent] Mark timer end   (\$PWD/.ended_at)
  aw report <name> "<note>"    [main agent] Append bilan + duration_seconds to reports.jsonl
                               Note prefix convention: ok|ko|partial — free text after
  aw archive <name>            Touch .archive (workspace done)
  aw revive <name>             Remove .archive
  aw list [--all|--archived]   List live workspaces by default
  aw context                   Print dense brief for an agent (shared/agent-brief.md)
  aw help                      This help

Launch in a workspace:    cd workspaces/<name> && claude
Archive check in script:  [ -f \$PWD/workspaces/<name>/.archive ] && echo archived || echo live

Config: $CONFIG_FILE
EOF
}

cmd_new() {
  if [ $# -ne 1 ]; then
    echo "Usage: aw new <name>" >&2; exit 1
  fi
  load_config
  local name="$1" target="$PWD/workspaces/$1"
  if [ -e "$target" ]; then
    echo "Error: workspace '$name' already exists at $target" >&2; exit 1
  fi
  local src="$REPO_PATH/shared/procedure.md"
  [ -f "$src" ] || { echo "Error: $src missing" >&2; exit 1; }

  mkdir -p "$target/inputs" "$target/outputs"
  touch "$target/outputs/.gitkeep"
  : > "$target/inputs/prompt.md"
  cp "$src" "$target/CLAUDE.md"
  cp "$src" "$target/AGENTS.md"

  echo "Created: $target"
  echo "Next: fill $target/inputs/prompt.md, then 'cd $target && claude'"
}

assert_in_workspace() {
  if [ ! -d "$PWD/inputs" ] || [ ! -d "$PWD/outputs" ]; then
    echo "Error: \$PWD does not look like a workspace (missing inputs/ or outputs/)." >&2
    echo "Cd into the workspace first." >&2
    exit 1
  fi
}

cmd_start() {
  [ $# -eq 0 ] || { echo "Usage: aw start (no args, from inside workspace)" >&2; exit 1; }
  assert_in_workspace
  date -u +%s > "$PWD/.started_at"
  echo "Timer started ($(date -u))"
}

cmd_end() {
  [ $# -eq 0 ] || { echo "Usage: aw end (no args, from inside workspace)" >&2; exit 1; }
  assert_in_workspace
  date -u +%s > "$PWD/.ended_at"
  echo "Timer ended   ($(date -u))"
}

cmd_report() {
  if [ $# -ne 2 ]; then
    echo "Usage: aw report <name> \"<note>\"" >&2; exit 1
  fi
  load_config
  local name="$1" note="$2" target="$PWD/workspaces/$1"
  local started_at="" ended_at="" duration=""
  [ -f "$target/.started_at" ] && started_at="$(cat "$target/.started_at")"
  [ -f "$target/.ended_at" ]   && ended_at="$(cat "$target/.ended_at")"
  if [ -n "$started_at" ] && [ -n "$ended_at" ]; then
    duration=$(( ended_at - started_at ))
  fi

  local ts; ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  mkdir -p "$(dirname "$REPORTS_PATH")"

  if [ -n "$duration" ]; then
    jq -nc --arg ts "$ts" --arg name "$name" --arg note "$note" \
           --argjson duration_seconds "$duration" \
           '{ts:$ts,name:$name,note:$note,duration_seconds:$duration_seconds}' >> "$REPORTS_PATH"
    echo "Appended report for '$name' (duration ${duration}s) to $REPORTS_PATH"
  else
    jq -nc --arg ts "$ts" --arg name "$name" --arg note "$note" \
           '{ts:$ts,name:$name,note:$note,duration_seconds:null}' >> "$REPORTS_PATH"
    if [ -z "$started_at" ] && [ -z "$ended_at" ]; then
      echo "Appended report for '$name' (no timer — aw start/end pas appelés) to $REPORTS_PATH" >&2
    elif [ -z "$ended_at" ]; then
      echo "Appended report for '$name' (aw end manquant) to $REPORTS_PATH" >&2
    fi
  fi
}

cmd_context() {
  load_config
  local brief="$REPO_PATH/shared/agent-brief.md"
  [ -f "$brief" ] || { echo "Error: $brief missing" >&2; exit 1; }
  cat "$brief"
}

cmd_archive() {
  [ $# -eq 1 ] || { echo "Usage: aw archive <name>" >&2; exit 1; }
  local target="$PWD/workspaces/$1"
  [ -d "$target" ] || { echo "Error: no workspace at $target" >&2; exit 1; }
  touch "$target/.archive"
  echo "Archived: $target"
}

cmd_revive() {
  [ $# -eq 1 ] || { echo "Usage: aw revive <name>" >&2; exit 1; }
  local target="$PWD/workspaces/$1"
  [ -d "$target" ] || { echo "Error: no workspace at $target" >&2; exit 1; }
  rm -f "$target/.archive"
  echo "Revived: $target"
}

cmd_list() {
  local mode=live
  while [ $# -gt 0 ]; do
    case "$1" in
      --all)      mode=all ;;
      --archived) mode=archived ;;
      *) echo "Error: unknown option '$1'." >&2; exit 1 ;;
    esac
    shift
  done

  local dir="$PWD/workspaces"
  if [ ! -d "$dir" ] || [ -z "$(ls -A "$dir" 2>/dev/null)" ]; then
    echo "No workspaces in $dir."
    echo "Create one with: aw new <name>"
    return 0
  fi

  if [ "$mode" = "all" ]; then
    printf "%-25s %-10s %-10s %-16s\n" "NAME" "STATUS" "INPUTS" "LAST MODIFIED"
    printf "%-25s %-10s %-10s %-16s\n" "----" "------" "------" "-------------"
  else
    printf "%-25s %-10s %-16s\n" "NAME" "INPUTS" "LAST MODIFIED"
    printf "%-25s %-10s %-16s\n" "----" "------" "-------------"
  fi

  local d name input_count mtime status
  for d in "$dir"/*/; do
    [ -d "$d" ] || continue
    name="$(basename "$d")"
    if [ -f "$d/.archive" ]; then status=archived; else status=live; fi
    case "$mode" in
      live)     [ "$status" = "live" ] || continue ;;
      archived) [ "$status" = "archived" ] || continue ;;
    esac
    input_count="$(find "$d/inputs" -mindepth 1 -not -name '.gitkeep' 2>/dev/null | wc -l)"
    mtime="$(date -r "$d" '+%Y-%m-%d %H:%M' 2>/dev/null || echo '?')"
    if [ "$mode" = "all" ]; then
      printf "%-25s %-10s %-10s %-16s\n" "$name" "$status" "$input_count files" "$mtime"
    else
      printf "%-25s %-10s %-16s\n" "$name" "$input_count files" "$mtime"
    fi
  done
}

if [ $# -eq 0 ]; then cmd_help; exit 0; fi
subcommand="$1"; shift
case "$subcommand" in
  new)            cmd_new "$@" ;;
  start)          cmd_start "$@" ;;
  end)            cmd_end "$@" ;;
  report)         cmd_report "$@" ;;
  archive)        cmd_archive "$@" ;;
  revive)         cmd_revive "$@" ;;
  list)           cmd_list "$@" ;;
  context)        cmd_context "$@" ;;
  help|-h|--help) cmd_help ;;
  *)
    echo "Unknown subcommand: $subcommand" >&2
    echo "" >&2
    cmd_help 1>&2
    exit 1
    ;;
esac
